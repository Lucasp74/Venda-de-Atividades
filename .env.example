# ─────────────────────────────────────────────────────────────
#  Copie este arquivo para .env.local e preencha as variáveis
#  NUNCA faça commit do .env.local — ele já está no .gitignore
# ─────────────────────────────────────────────────────────────

# URL pública do site (sem barra final)
NEXT_PUBLIC_BASE_URL=https://seu-dominio.vercel.app

# Payload CMS — gere uma string forte (ex: openssl rand -base64 32)
PAYLOAD_SECRET=TROQUE_POR_UMA_CHAVE_SECRETA_FORTE


# ── Banco de dados ────────────────────────────────────────────
# PRODUÇÃO (Vercel): PostgreSQL — use Vercel Postgres ou Neon (neon.tech — gratuito)
# Exemplo Neon: postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://...

# DEV LOCAL: SQLite (não precisa configurar DATABASE_URL no desenvolvimento)
DATABASE_URI=file:./database.db


# ── Vercel Blob Storage ───────────────────────────────────────
# PRODUÇÃO: necessário para upload de imagens e PDFs na Vercel
# Obtenha em: Vercel Dashboard → Storage → Blob → seu store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...


# ── Mercado Pago (Gateway de Pagamento) ───────────────────────
# Obtenha em: mercadopago.com.br → Seu negócio → Credenciais
# Use TEST- para testes e APP_USR- para produção
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Chave secreta para verificar assinaturas dos webhooks
# Configure em: Mercado Pago → Webhooks → Definir chave secreta
# URL do webhook: https://seu-dominio.vercel.app/api/mercadopago/webhook
MERCADOPAGO_WEBHOOK_SECRET=


# ── Resend (Envio de E-mails) ─────────────────────────────────
# Obtenha em: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Domínio verificado no Resend para envio (ex: profdani.com.br)
EMAIL_DOMAIN=profdani.com.br


# ── Google Analytics 4 (opcional) ────────────────────────────
# Obtenha em: analytics.google.com → Administrador → Fluxos de dados
# Formato: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# API Secret para eventos server-side via Measurement Protocol
# Encontre em: GA4 → Administrador → Fluxo de dados → Segredos de API do Measurement Protocol
GA_API_SECRET=


# ── Google Ads (opcional) ─────────────────────────────────────
# Obtenha em: ads.google.com → Ferramentas → Conversões
# ID da conta — formato: AW-XXXXXXXXX
NEXT_PUBLIC_GADS_ID=

# Rótulo da conversão de compra
# Encontre em: Google Ads → Conversões → [Nome da conversão] → Marcador de evento
NEXT_PUBLIC_GADS_PURCHASE_LABEL=
